DATABASE_URL=postgresql+psycopg://traceflow:traceflow@localhost:5432/traceflow
REDIS_URL=redis://localhost:6379/0
EVAL_QUEUE_NAME=eval
OPENAI_API_KEY=
OPENAI_EVAL_MODEL=gpt-4o-mini

# GitHub OAuth — create an app at https://github.com/settings/developers
# Homepage URL:               http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Frontend API URL (used by the Next.js app to reach the FastAPI backend)
NEXT_PUBLIC_TRACEFLOW_API_URL=http://localhost:8000
