DATABASE_URL=postgresql+psycopg://traceflow:traceflow@localhost:5432/traceflow
REDIS_URL=redis://localhost:6379/0
EVAL_QUEUE_NAME=eval
OPENAI_API_KEY=
OPENAI_EVAL_MODEL=gpt-4o-mini

# GitHub OAuth — create an app at https://github.com/settings/developers
# Set the "Authorization callback URL" to: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-in-production

# URL of the frontend (used for OAuth redirect and CORS)
FRONTEND_URL=http://localhost:3000
